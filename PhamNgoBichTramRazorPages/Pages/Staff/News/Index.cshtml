@page
@model PhamNgoBichTramRazorPages.Pages.Staff.News.IndexModel
@{
    ViewData["Title"] = "News Management";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">News Articles</h2>
    <button class="btn btn-primary" type="button" onclick="openCreate()">Create</button>
</div>

<form method="get" class="d-flex gap-2 mb-3">
    <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Search title/headline/content..." />
    <button class="btn btn-outline-primary" type="submit">Search</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Toast))
{
    <div class="alert alert-info">@Model.Toast</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle" id="newsTable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.News)
            {
                <tr>
                    <td>@n.NewsArticleID</td>
                    <td>@(!string.IsNullOrWhiteSpace(n.NewsTitle) ? n.NewsTitle : n.Headline)</td>
                    <td>@(n.Category?.CategoryName ?? "N/A")</td>
                    <td>@(n.NewsStatus == true ? "Active" : "Inactive")</td>
                    <td>@n.CreatedDate?.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" type="button" onclick="openEdit('@n.NewsArticleID')">Edit</button>
                        <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete this news article?');">
                            <input type="hidden" name="id" value="@n.NewsArticleID" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="newsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header">
                    <h5 class="modal-title" id="newsModalTitle">News</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Mode" id="Mode" value="Create" />
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">News ID</label>
                            <input class="form-control" name="Article.NewsArticleId" id="NewsArticleId" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Title</label>
                            <input class="form-control" name="Article.NewsTitle" id="NewsTitle" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Headline *</label>
                            <input class="form-control" name="Article.Headline" id="Headline" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <select class="form-select" name="Article.CategoryId" id="CategoryId">
                                <option value="">-- Select --</option>
                                @foreach (var c in Model.AllCategories)
                                {
                                    <option value="@c.CategoryID">@c.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="Article.NewsStatus" id="NewsStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Source</label>
                            <input class="form-control" name="Article.NewsSource" id="NewsSource" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Content</label>
                            <textarea class="form-control" name="Article.NewsContent" id="NewsContent" rows="6"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Tags</label>
                            <select class="form-select" name="TagIds" id="TagIds" multiple size="5">
                                @foreach (var t in Model.AllTags)
                                {
                                    <option value="@t.TagID">@t.TagName</option>
                                }
                            </select>
                            <div class="form-text">Hold Ctrl/Cmd to select multiple tags.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.24/signalr.min.js" integrity="" crossorigin="anonymous"></script>
    <script>
        const modalEl = document.getElementById('newsModal');
        const modal = new bootstrap.Modal(modalEl);

        function setSelectedTags(ids) {
            const select = document.getElementById('TagIds');
            for (const opt of select.options) {
                opt.selected = ids.includes(parseInt(opt.value));
            }
        }

        function openCreate() {
            document.getElementById('newsModalTitle').innerText = 'Create News';
            document.getElementById('Mode').value = 'Create';
            document.getElementById('NewsArticleId').readOnly = false;
            document.getElementById('NewsArticleId').value = '';
            document.getElementById('NewsTitle').value = '';
            document.getElementById('Headline').value = '';
            document.getElementById('CategoryId').value = '';
            document.getElementById('NewsStatus').value = 'true';
            document.getElementById('NewsSource').value = '';
            document.getElementById('NewsContent').value = '';
            setSelectedTags([]);
            modal.show();
        }

        async function openEdit(id) {
            const res = await fetch(`?handler=News&id=${encodeURIComponent(id)}`);
            const n = await res.json();
            document.getElementById('newsModalTitle').innerText = 'Update News';
            document.getElementById('Mode').value = 'Update';
            document.getElementById('NewsArticleId').readOnly = true;
            document.getElementById('NewsArticleId').value = n.newsArticleId;
            document.getElementById('NewsTitle').value = n.newsTitle ?? '';
            document.getElementById('Headline').value = n.headline ?? '';
            document.getElementById('CategoryId').value = (n.categoryId ?? '').toString();
            document.getElementById('NewsStatus').value = (n.newsStatus === true).toString();
            document.getElementById('NewsSource').value = n.newsSource ?? '';
            document.getElementById('NewsContent').value = n.newsContent ?? '';
            setSelectedTags(n.tagIds ?? []);
            modal.show();
        }

        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/news").withAutomaticReconnect().build();
        connection.on("NewsChanged", () => window.location.reload());
        connection.start().catch(() => {});
    </script>
}


