@page
@model PhamNgoBichTramRazorPages.Pages.Staff.History.IndexModel
@{
    ViewData["Title"] = "My News History";
}

<h2 class="mb-3">My News History</h2>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.News)
            {
                <tr>
                    <td>@n.NewsArticleID</td>
                    <td>@(!string.IsNullOrWhiteSpace(n.NewsTitle) ? n.NewsTitle : n.Headline)</td>
                    <td>@(n.Category?.CategoryName ?? "N/A")</td>
                    <td>@(n.NewsStatus == true ? "Active" : "Inactive")</td>
                    <td>@n.CreatedDate?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>


