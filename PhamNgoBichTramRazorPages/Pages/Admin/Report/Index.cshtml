@page
@model PhamNgoBichTramRazorPages.Pages.Admin.Report.IndexModel
@{
    ViewData["Title"] = "Report";
}

<h2 class="mb-3">News Report</h2>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label">Start date</label>
        <input class="form-control" type="date" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-4">
        <label class="form-label">End date</label>
        <input class="form-control" type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-4">
        <button class="btn btn-primary w-100" type="submit">Generate</button>
    </div>
</form>

@if (Model.Items is not null)
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Created By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var n in Model.Items)
                {
                    <tr>
                        <td>@n.CreatedDate?.ToString("yyyy-MM-dd")</td>
                        <td>@n.NewsArticleID</td>
                        <td>@(!string.IsNullOrWhiteSpace(n.NewsTitle) ? n.NewsTitle : n.Headline)</td>
                        <td>@(n.Category?.CategoryName ?? "N/A")</td>
                        <td>@(n.CreatedBy?.AccountName ?? n.CreatedBy?.AccountEmail ?? "N/A")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}


