@page
@model PhamNgoBichTramRazorPages.Pages.Admin.Accounts.IndexModel
@{
    ViewData["Title"] = "Account Management";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Accounts</h2>
    <button class="btn btn-primary" type="button" onclick="openCreate()">Create</button>
</div>

<form method="get" class="d-flex gap-2 mb-3">
    <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Search name/email..." />
    <button class="btn btn-outline-primary" type="submit">Search</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Toast))
{
    <div class="alert alert-info">@Model.Toast</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Accounts)
            {
                <tr>
                    <td>@a.AccountID</td>
                    <td>@a.AccountName</td>
                    <td>@a.AccountEmail</td>
                    <td>@(a.AccountRole == 1 ? "Staff" : a.AccountRole == 2 ? "Lecturer" : "N/A")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" type="button" onclick="openEdit(@a.AccountID)">Edit</button>
                        <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete this account?');">
                            <input type="hidden" name="id" value="@a.AccountID" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header">
                    <h5 class="modal-title" id="accountModalTitle">Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Mode" id="Mode" value="Create" />

                    <input type="hidden" name="Account.AccountID" id="HiddenAccountId" />

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Account ID</label>
                            <input class="form-control" id="DisplayAccountId" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Name</label>
                            <input class="form-control" name="Account.AccountName" id="AccountName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" name="Account.AccountEmail" id="AccountEmail" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Role</label>
                            <select class="form-select" name="Account.AccountRole" id="AccountRole">
                                <option value="1">Staff</option>
                                <option value="2">Lecturer</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Password</label>
                            <input class="form-control" name="Account.AccountPassword" id="AccountPassword" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modalEl = document.getElementById('accountModal');
        const modal = new bootstrap.Modal(modalEl);

        function openCreate() {
            document.getElementById('accountModalTitle').innerText = 'Create Account';
            document.getElementById('Mode').value = 'Create';

            document.getElementById('DisplayAccountId').disabled = false;
            document.getElementById('DisplayAccountId').value = '';
            document.getElementById('HiddenAccountId').value = '';

            document.getElementById('AccountName').value = '';
            document.getElementById('AccountEmail').value = '';
            document.getElementById('AccountRole').value = '1';
            document.getElementById('AccountPassword').value = '';

            document.getElementById('DisplayAccountId').oninput = function() {
                document.getElementById('HiddenAccountId').value = this.value;
            };

            modal.show();
        }

        async function openEdit(id) {
            const res = await fetch(`?handler=Account&id=${id}`);
            const a = await res.json();

            document.getElementById('accountModalTitle').innerText = 'Update Account';
            document.getElementById('Mode').value = 'Update';

          
            document.getElementById('DisplayAccountId').disabled = true;

     
            document.getElementById('DisplayAccountId').value = a.accountID ?? a.accountId;
            document.getElementById('HiddenAccountId').value = a.accountID ?? a.accountId;

            document.getElementById('AccountName').value = a.accountName ?? '';
            document.getElementById('AccountEmail').value = a.accountEmail ?? '';
            document.getElementById('AccountRole').value = (a.accountRole ?? 1).toString();
            document.getElementById('AccountPassword').value = a.accountPassword ?? '';

          
            document.getElementById('DisplayAccountId').oninput = null;

            modal.show();
        }
    </script>
}